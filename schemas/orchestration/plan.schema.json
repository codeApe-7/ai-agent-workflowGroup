{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://aigroup.dev/schemas/orchestration/plan.schema.json",
  "title": "Session Plan",
  "description": "Aggregated session-level view: workers, dependency graph, and bucketed status. Regenerated by `session.cjs plan`.",
  "type": "object",
  "required": ["schemaVersion", "session", "generatedAt", "workers", "buckets"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "session": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "workers": {
      "type": "array",
      "description": "All workers with their current state + dependencies (snapshot).",
      "items": {
        "type": "object",
        "required": ["name", "agent", "state"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "agent": { "type": "string" },
          "state": {
            "type": "string",
            "enum": ["not_started", "running", "blocked", "completed", "failed"]
          },
          "lightweight": { "type": "boolean" },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "objective": { "type": "string" },
          "finalizedAt": { "type": ["string", "null"], "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "buckets": {
      "type": "object",
      "description": "Workers grouped by computed status. `ready` = not_started + all dependencies completed.",
      "required": ["ready", "running", "blocked", "completed", "failed", "waiting"],
      "properties": {
        "ready": { "type": "array", "items": { "type": "string" } },
        "running": { "type": "array", "items": { "type": "string" } },
        "blocked": { "type": "array", "items": { "type": "string" } },
        "completed": { "type": "array", "items": { "type": "string" } },
        "failed": { "type": "array", "items": { "type": "string" } },
        "waiting": {
          "type": "array",
          "items": { "type": "string" },
          "description": "not_started but at least one dependency not yet completed."
        }
      },
      "additionalProperties": false
    }
  }
}
