{
  "PostToolUse": [
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/hooks/dispatcher.cjs post-edit",
          "timeout": 10
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/hooks/dispatcher.cjs stop",
          "timeout": 30
        }
      ]
    }
  ],
  "SubagentStop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/hooks/dispatcher.cjs subagent-stop",
          "timeout": 15
        }
      ]
    }
  ]
}
