{
  "PostToolUse": [
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "bash scripts/harness/hook-post-edit.sh",
          "timeout": 10
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "bash scripts/harness/hook-stop.sh",
          "timeout": 30
        }
      ]
    }
  ]
}
